# fastlane Fastfile — CI → TestFlight deploy pipeline (issue #135).
#
# Two lanes, sharing one archive path:
#   • build_only — archive + sign a Release .ipa, NO upload. The bring-up step-2
#                  isolator: proves runner + Xcode pin + signing + secret loading
#                  without touching App Store Connect. Runnable independently.
#   • beta       — build_only's archive → upload to TestFlight (internal) → poll
#                  App Store Connect until the build's processingState is VALID
#                  (bounded timeout; fails the run on INVALID / timeout).
#
# Signing (see the issue's "Signing" section): Apple offers no server-side
# distribution signing, so a real Apple Distribution cert + App Store profile must
# be on the runner. We use `match(appstore)` in READONLY mode — cert + key + profile
# live encrypted in a private git repo and are imported into a TEMPORARY keychain
# created by `setup_ci`. The ASC API key is AUTH ONLY (upload + profile refresh); it
# is NOT a signing substitute. The project is CODE_SIGN_STYLE=Automatic with no
# profile specifier, so match overrides to manual signing for the archive.
#
# Required environment (provided by the `testflight` GitHub Environment secrets —
# NEVER hard-coded, NEVER echoed; see .github/workflows/testflight.yml):
#   ASC_KEY_ID                — App Store Connect API key id
#   ASC_ISSUER_ID             — App Store Connect API issuer id
#   ASC_KEY_CONTENT_BASE64    — base64 of the .p8 private key (key_content, no temp file)
#   MATCH_GIT_URL             — the private certs/profiles repo (match storage)
#   MATCH_PASSWORD            — passphrase decrypting the match repo
#   MATCH_GIT_BASIC_AUTHORIZATION — base64 "user:token" for read access to MATCH_GIT_URL
#   GITHUB_RUN_NUMBER         — injected by Actions; becomes CURRENT_PROJECT_VERSION
#
# Secret hygiene: no `set -x`, no `--verbose`. The temp keychain from setup_ci is
# torn down automatically at the end of the CI job.

default_platform(:ios)

# --- Shared configuration ----------------------------------------------------

APP_IDENTIFIER = "com.valtteriluoma.poimi".freeze
XCODEPROJ      = "App/PoimiApp.xcodeproj".freeze
SCHEME         = "PoimiApp".freeze
OUTPUT_DIR     = "build".freeze
OUTPUT_NAME    = "PoimiApp".freeze

# How long to wait for App Store Connect to finish processing the upload before
# failing the run (issue AC: fail unless processingState == VALID within a bound).
PROCESSING_TIMEOUT_SECONDS = 1800 # 30 minutes
PROCESSING_POLL_SECONDS    = 30

# Build the App Store Connect API key hash once (key_content, base64 — no temp file
# on disk). Reused by match, upload, and the processing poll.
def asc_api_key
  @asc_api_key ||= app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_CONTENT_BASE64"),
    is_key_content_base64: true,
    in_house: false
  )
end

# The build number for this run: GITHUB_RUN_NUMBER is monotonic + unique per upload,
# so no agvtool (the plist is synthesized) and no ASC round-trip. Local runs (no
# Actions env) fall back to a timestamp so build_only still works off-CI.
def build_number
  ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
end

platform :ios do
  # --- build_only: archive + signed .ipa, no upload -------------------------
  desc "Archive + sign a Release .ipa (no upload). Bring-up step 2 isolator."
  lane :build_only do
    setup_ci # temporary keychain on CI; no-op locally

    match(
      type: "appstore",
      readonly: true,
      app_identifier: APP_IDENTIFIER,
      api_key: asc_api_key
    )

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: OUTPUT_DIR,
      output_name: "#{OUTPUT_NAME}.ipa",
      # Predictable archive location so CI can upload its Info.plist as an artifact (AC).
      archive_path: File.join(OUTPUT_DIR, "#{OUTPUT_NAME}.xcarchive"),
      # Inject the build number at archive time — VERSIONING_SYSTEM is unset and the
      # Info.plist is synthesized, so agvtool/increment_build_number cannot bump it.
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}"
    )

    UI.success("Archived #{OUTPUT_NAME}.ipa (build #{build_number}).")
  end

  # --- beta: build_only + upload to TestFlight (internal) + processing poll --
  desc "Build, upload to TestFlight (internal), and fail unless the build reaches VALID."
  lane :beta do
    build_only

    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      ipa: File.join(OUTPUT_DIR, "#{OUTPUT_NAME}.ipa"),
      distribute_external: false,          # internal testers only (no Beta App Review)
      skip_submission: true,               # do not submit for external review
      skip_waiting_for_build_processing: true # we poll explicitly below for a falsifiable VALID
    )

    processing_state = wait_for_valid_build(build_number)

    summarize(build_number, processing_state)
  end

  # Poll App Store Connect for THIS run's build until it is VALID. Raises (fails the
  # run non-zero) on INVALID or on timeout — satisfying the falsifiable acceptance
  # criterion that "upload returned 0" is not sufficient.
  def wait_for_valid_build(expected_build)
    require "spaceship"
    require "base64"

    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key: Base64.decode64(ENV.fetch("ASC_KEY_CONTENT_BASE64"))
    )
    Spaceship::ConnectAPI.token = token

    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    UI.user_error!("No App Store Connect app record for #{APP_IDENTIFIER}") if app.nil?

    deadline = Time.now + PROCESSING_TIMEOUT_SECONDS
    loop do
      build = app.get_builds(
        filter: { "version" => expected_build.to_s },
        includes: "preReleaseVersion"
      ).first

      state = build&.processing_state
      UI.message("ASC build #{expected_build}: #{state || 'not visible yet'}")

      case state
      when "VALID"
        return state
      when "INVALID"
        UI.user_error!("Build #{expected_build} finished processing as INVALID.")
      end

      if Time.now > deadline
        UI.user_error!("Timed out after #{PROCESSING_TIMEOUT_SECONDS}s waiting for build #{expected_build} to become VALID (last state: #{state || 'unseen'}).")
      end

      sleep(PROCESSING_POLL_SECONDS)
    end
  end

  # Echo the build number + TestFlight/ASC URL to the GitHub step summary (AC).
  def summarize(build, state)
    app_url = "https://appstoreconnect.apple.com/apps"
    line = "TestFlight build **#{build}** reached ASC processingState **#{state}**. " \
           "View in App Store Connect → TestFlight: #{app_url}"
    UI.success(line)

    summary_path = ENV["GITHUB_STEP_SUMMARY"]
    return if summary_path.nil? || summary_path.empty?

    File.open(summary_path, "a") do |f|
      f.puts("### TestFlight upload")
      f.puts("")
      f.puts("- Build number: `#{build}`")
      f.puts("- ASC processingState: `#{state}`")
      f.puts("- App Store Connect (TestFlight): #{app_url}")
    end
  end
end
